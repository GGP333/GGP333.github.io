  year         = {2024},
  month        = {July},
  type         = {Undergraduate Thesis},
  abstract     = {This work introduces a Swin UNETR-based pipeline for 3D semantic segmentation of brain tumors in multi-contrast MRI, achieving a Dice score of 0.89 on the BraTS dataset. The model leverages attention-based intermediate-layer extraction and Grad-CAM to provide visually understandable interpretability, aiming to enhance trust and clinical adoption of AI-driven segmentation tools.}
